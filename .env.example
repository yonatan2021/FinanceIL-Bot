# ==============================================================================
# ENVIRONMENT VARIABLES TEMPLATE
# DO NOT ADD REAL SECRETS IN THIS FILE!
# This file is committed to version control.
# Copy this file to `.env` or `.env.local` to configure your environment.
# ==============================================================================

# -----------------
# Security (CRITICAL)
# -----------------
# 32-byte (256-bit) encryption key used for SQLite database encryption AND field-level encryption.
# MUST NOT BE EXPOSED TO CLIENT.
ENCRYPTION_KEY=replace-with-your-32-byte-hex-key

# NextAuth / better-auth secret
AUTH_SECRET=your-random-secret-at-least-32-chars

# Password for the dashboard
DASHBOARD_PASSWORD=your-secure-password

# -----------------
# Databases
# -----------------
DATABASE_URL=file:./data.db
AUTH_DB_URL=file:./auth.db

# -----------------
# Telegram Bot
# -----------------
BOT_TOKEN=your_bot_token_here

# -----------------
# Bot Tuning (optional — defaults shown)
# -----------------
# Minimum interval (ms) between lastSeenAt DB writes per user in auth middleware
AUTH_LASTSEEN_INTERVAL_MS=300000

# Delay (ms) between each message send in scheduled broadcasts (rate-limit safety)
SCHEDULER_SEND_DELAY_MS=50

# Maximum results returned by transaction search queries (default: 20)
SEARCH_MAX_RESULTS=20

# -----------------
# Internal API
# -----------------
INTERNAL_API_SECRET=your-internal-api-secret-32-chars

# -----------------
# Next.js / Web
# -----------------
NEXT_PUBLIC_APP_URL=http://localhost:5200
PORT=5200

# -----------------
# Application Environment
# -----------------
NODE_ENV=development
